generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model RagChunk {
  id          String   @id @db.VarChar(32)
  text        String   @db.Text
  source      String   @db.VarChar(120)
  docType     String   @map("doc_type") @db.VarChar(32)
  kategori    String   @db.VarChar(80)
  tanggal     String?  @db.VarChar(40)
  userSegment String   @map("user_segment") @db.VarChar(16)
  chunkIndex  Int      @map("chunk_index")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([docType])
  @@index([kategori])
  @@index([userSegment])
  @@map("rag_chunks")
}

model DemoTransaction {
  id          Int      @id @default(autoincrement())
  userSegment String   @map("user_segment") @db.VarChar(16)
  owner       String   @db.VarChar(80)
  date        DateTime
  category    String   @db.VarChar(60)
  description String   @db.VarChar(160)
  amount      Int
  budget      Int?
  source      String   @db.VarChar(120)

  @@index([userSegment])
  @@index([category])
  @@map("demo_transactions")
}

model DemoQuestion {
  id          Int    @id @default(autoincrement())
  label       String @db.VarChar(100)
  question    String @db.Text
  userSegment String @map("user_segment") @db.VarChar(16)
  docType     String @map("doc_type") @db.VarChar(32)

  @@map("demo_questions")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(80)
  email     String   @unique @db.VarChar(80)
  password  String   @db.VarChar(80)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Wallet {
  id         Int      @id @default(autoincrement())
  userEmail  String   @map("user_email") @db.VarChar(80)
  name       String   @db.VarChar(80)
  balance    Float
  cardNumber String   @map("card_number") @db.VarChar(40)
  designType String   @map("design_type") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userEmail])
  @@map("wallets")
}

model Transaction {
  id         String   @id @db.VarChar(40)
  userEmail  String   @map("user_email") @db.VarChar(80)
  title      String   @db.VarChar(120)
  category   String   @db.VarChar(60)
  date       DateTime
  amount     Float
  isExpense  Boolean  @map("is_expense")
  walletName String   @map("wallet_name") @db.VarChar(80)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userEmail])
  @@map("transactions")
}
